# Copy this file to .env and fill in your actual API keys.
# Never commit .env to version control.

# Google Gemini API key (used by comps.py and forecast.py)
GEMINI_API_KEY=your_gemini_api_key_here

# Financial data API keys (used by dcf_value.py and comprehensive_financial_dashboard.py)
FRED_API_KEY=your_fred_api_key_here
FMP_API_KEY=your_fmp_api_key_here
TIINGO_API_KEY=your_tiingo_api_key_here
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here

# GitHub personal access token (used by sentiment_analysis.py)
GITHUB_TOKEN=your_github_token_here

# LinkedIn credentials (used by sentiment_analysis.py — unofficial API, use with caution)
LINKEDIN_USER=your_linkedin_email_here
LINKEDIN_PASSWORD=your_linkedin_password_here